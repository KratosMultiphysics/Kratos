<?xml version="1.0" encoding="utf-8"?><!-- -*- coding: utf-8; mode: SGML -*- -->
<Kratos_data version="9.5.1">
  <style show_menubutton_about="0" show_menubutton_search="1"/>
  <groups>
    <group n="Parts Auto1" onoff="1" color="magenta" type=""/>
    <group n="Automatic inlet velocity Auto1" onoff="1" color="green" type=""/>
    <group n="Automatic inlet velocity Auto1//Total" onoff="1" color="#ff00ff" type=""/>
    <group n="Outlet pressure Auto1" onoff="1" color="yellow" type=""/>
    <group n="No Slip Auto1" onoff="1" color="orange" type=""/>
    <group n="Parts Auto1//Initial" onoff="1" color="#00ff00" type=""/>
    <group n="Automatic inlet velocity Auto1//Total - 0" onoff="1" color="#996600" type=""/>
  </groups>
  <units/>
  <!-- Fill this fields to automatically active an App without the init window -->
  <hiddenfield n="activeapp" active="0" v="Buoyancy" state="disabled"/>
  <value n="nDim" pn="Dimension" un="nDim" v="3D" state="disabled" values="undefined,2D,2Da,3D" dict="undefined,Undefined,2D,2D,2Da,2D axisymmetric,3D,3D" tree_state="selected,close" actualize="1" actualize_tree="1"/>
  <appLink n="ThermicLauncher" public="1" pn="Thermic" active="0" appid="ThermicLauncher" prefix="ThermicLauncher"/>
  <appLink n="ConvectionDiffusion" public="0" pn="Convection-diffusion" active="0" appid="ConvectionDiffusion" prefix="CNVDFF"/>
  <appLink n="Structural" public="1" pn="Structural" active="0" appid="Structural" prefix="ST"/>
  <appLink n="FluidLauncher" public="1" pn="Fluid" active="0" appid="FluidLauncher" prefix="FLL"/>
  <appLink n="Fluid" public="0" pn="Fluid" active="0" appid="Fluid" prefix="FL"/>
  <appLink n="CompressibleFluid" public="0" pn="Compressible Fluid" active="0" appid="CompressibleFluid" prefix="CF"/>
  <appLink n="EmbeddedFluid" public="0" pn="Embedded fluid" active="0" appid="EmbeddedFluid" prefix="EMBFL"/>
  <container n="Buoyancy" pn="Buoyancy" icon="app" prefix="Buoyancy_" tree_state="open" open_window="0">
    <container n="Fluid" pn="Fluid" icon="units" prefix="FL" tree_state="close" open_window="0">
      <container n="AnalysisType" pn="Analysis Type" help="Analysis information" icon="analysis" state="normal" open_window="0" tree_state="close">
        <value n="FreeSurface" pn="Free Surface" un="FLFreeSurface" v="No" values="Yes,No" help="Analysis type" state="hidden"/>
        <value n="SolStrat" pn="Solution Strategy" un="FLSolStrat" v="Monolithic" values="Monolithic,FractionalStep" dict="[GetSolutionStrategies App Fluid]" actualize_tree="1"/>
        <value n="Scheme" pn="Scheme" un="FLScheme" v="bossak" values="bossak,bdf2" dict="[GetSchemes]" actualize_tree="1"/>
      </container>
      <condition n="FluidParts" pn="Parts" ov="[CheckGeometry 1]" icon="reservoir16" help="Select your group" un="FLParts" update_proc="UpdateParts" tree_state="close">
        <value n="Element" pn="Element" v="QSVMS3D" dict="[GetElements]" actualize="1" values="QSVMS3D,DVMS3D,FIC3D" state="">
          <dependencies node="../value[@n!='Material']" actualize="1"/>
        </value>
        <value n="ConstitutiveLaw" pn="Fluid type" v="Newtonian3DLaw" actualize_tree="1" values="[GetConstitutiveLaws]" dict="[GetAllConstitutiveLaws]" state="">
          <dependencies node="../value[@n!='Material']" actualize="1"/>
        </value>
        <value n="Material" pn="Material" state="disabled" help="Choose a material from the database" v="Air" values="[GetMaterialsList]">
          <edit_command n="Edit materials" pn="Edit materials" icon="refresh.png" proc="EditDatabaseList"/>
        </value>
        <value n="DENSITY" pn="Density" v="1.225" units="kg/m^3" unit_magnitude="Density" help="Density" string_is="double" state="[PartParamState]" show_in_window="1"/>
        <value n="DYNAMIC_VISCOSITY" pn="Dynamic viscosity" v="1.846e-5" units="kg/(m*s)" unit_magnitude="M/(L*T)" help="Set the dynamic viscosity." string_is="double" state="[PartParamState]" show_in_window="1"/>
        <value n="CONDUCTIVITY" pn="Thermal conductivity" v="0.024" units="W/(m*K)" unit_magnitude="Power/(L*Temp)" help="Thermal conductivity" string_is="double" state="[PartParamState]" show_in_window="1"/>
        <value n="SPECIFIC_HEAT" pn="Specific heat" v="1012.0" units="J/(kg*K)" unit_magnitude="Energy/(M*Temp)" help="Specific heat" string_is="double" state="[PartParamState]" show_in_window="1"/>
        <value n="SOUND_VELOCITY" pn="Sound velocity" v="1.0e+12" units="m/s" unit_magnitude="L/T" help="Set the sound velocity." string_is="double" state="[PartParamState]" show_in_window="1"/>
        <group n="Parts Auto1" ov="volume" tree_state="close">
          <value n="Element" pn="Element" dict="[GetElements]" actualize="1" values="QSVMS3D,DVMS3D,FIC3D" state="normal" v="QSVMS3D" tree_state="close"/>
          <value n="ConstitutiveLaw" pn="Fluid type" actualize_tree="1" values="[GetConstitutiveLaws]" dict="[GetAllConstitutiveLaws]" state="normal" v="Newtonian3DLaw" tree_state="close"/>
          <value n="Material" pn="Material" state="disabled" help="Choose a material from the database" values="[GetMaterialsList]" v="Air" tree_state="close"/>
          <value n="DENSITY" pn="Density" unit_magnitude="Density" help="Density" string_is="double" state="[PartParamState]" show_in_window="1" v="1.225" units="kg/m^3" tree_state="close"/>
          <value n="DYNAMIC_VISCOSITY" pn="Dynamic viscosity" unit_magnitude="M/(L*T)" help="Set the dynamic viscosity." string_is="double" state="[PartParamState]" show_in_window="1" v="1.846e-5" units="kg/(m*s)" tree_state="close"/>
          <value n="CONDUCTIVITY" pn="Thermal conductivity" unit_magnitude="Power/(L*Temp)" help="Thermal conductivity" string_is="double" state="[PartParamState]" show_in_window="1" v="0.024" units="W/(m*K)" tree_state="close"/>
          <value n="SPECIFIC_HEAT" pn="Specific heat" unit_magnitude="Energy/(M*Temp)" help="Specific heat" string_is="double" state="[PartParamState]" show_in_window="1" v="1012.0" units="J/(kg*K)" tree_state="close"/>
          <value n="SOUND_VELOCITY" pn="Sound velocity" unit_magnitude="L/T" help="Set the sound velocity." string_is="double" state="[PartParamState]" show_in_window="1" v="1.0e+12" units="m/s"/>
        </group>
      </condition>
      <container n="InitialConditions" pn="Initial Conditions" un="FLNodalConditions" icon="air" open_window="0" tree_state="close">
        <condition n="VELOCITY" pn="Velocity" ov="point,line,surface,volume" ovm="" icon="shells16" help="Velocity" state="[CheckNodalConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
          <value n="selector_component_X" pn="Component X" v="ByValue" values="ByFunction,ByValue,Not" dict="ByFunction,By function,ByValue,By value,Not,Not set" state="[ConditionParameterState]" help="Component" show_in_window="1" cal_state="normal">
            <dependencies value="Not" node="../value[@n='value_component_X']" att1="state" v1="hidden"/>
            <dependencies value="Not" node="../value[@n='function_component_X']" att1="state" v1="hidden"/>
            <dependencies value="ByValue" node="../value[@n='value_component_X']" att1="state" v1="normal"/>
            <dependencies value="ByFunction" node="../value[@n='value_component_X']" att1="state" v1="hidden"/>
            <dependencies value="ByValue" node="../value[@n='function_component_X']" att1="state" v1="hidden"/>
            <dependencies value="ByFunction" node="../value[@n='function_component_X']" att1="state" v1="normal"/>
          </value>
          <value n="function_component_X" pn="Function X (x,y,z,t)" v="2*x" help="Component" state="hidden"/>
          <value n="value_component_X" wn="VELOCITY _X" pn="Value X" v="0.0" units="m/s" unit_magnitude="Velocity" help="Component" show_in_window="1"/>
          <value n="selector_component_Y" pn="Component Y" v="ByValue" values="ByFunction,ByValue,Not" dict="ByFunction,By function,ByValue,By value,Not,Not set" state="[ConditionParameterState]" help="Component" show_in_window="1" cal_state="normal">
            <dependencies value="Not" node="../value[@n='value_component_Y']" att1="state" v1="hidden"/>
            <dependencies value="Not" node="../value[@n='function_component_Y']" att1="state" v1="hidden"/>
            <dependencies value="ByValue" node="../value[@n='value_component_Y']" att1="state" v1="normal"/>
            <dependencies value="ByFunction" node="../value[@n='value_component_Y']" att1="state" v1="hidden"/>
            <dependencies value="ByValue" node="../value[@n='function_component_Y']" att1="state" v1="hidden"/>
            <dependencies value="ByFunction" node="../value[@n='function_component_Y']" att1="state" v1="normal"/>
          </value>
          <value n="function_component_Y" pn="Function Y (x,y,z,t)" v="2*x" help="Component" state="hidden"/>
          <value n="value_component_Y" wn="VELOCITY _Y" pn="Value Y" v="0.0" units="m/s" unit_magnitude="Velocity" help="Component" show_in_window="1"/>
          <value n="selector_component_Z" pn="Component Z" v="ByValue" values="ByFunction,ByValue,Not" dict="ByFunction,By function,ByValue,By value,Not,Not set" state="[CheckDimension 3D]" help="Component" show_in_window="1">
            <dependencies value="Not" node="../value[@n='value_component_Z']" att1="state" v1="hidden"/>
            <dependencies value="Not" node="../value[@n='function_component_Z']" att1="state" v1="hidden"/>
            <dependencies value="ByValue" node="../value[@n='value_component_Z']" att1="state" v1="normal"/>
            <dependencies value="ByFunction" node="../value[@n='value_component_Z']" att1="state" v1="hidden"/>
            <dependencies value="ByValue" node="../value[@n='function_component_Z']" att1="state" v1="hidden"/>
            <dependencies value="ByFunction" node="../value[@n='function_component_Z']" att1="state" v1="normal"/>
          </value>
          <value n="function_component_Z" pn="Function Z (x,y,z,t)" v="2*x" help="Component" state="hidden"/>
          <value n="value_component_Z" wn="VELOCITY _Z" pn="Value Z" v="0.0" units="m/s" unit_magnitude="Velocity" help="Component" state="[CheckDimension 3D]" show_in_window="1"/>
        </condition>
        <condition n="PRESSURE" pn="Pressure" ov="point,line,surface,volume" ovm="" icon="shells16" help="Pressure" state="[CheckNodalConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
          <value n="constrained" pn="Imposed" v="false" values="true,false" help="Imposed" state="hidden" show_in_window="1"/>
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='value']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='value']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_value']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_value']" att1="state" v1="normal"/>
          </value>
          <value n="function_value" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="value" pn="Value" v="0.0" units="Pa" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
        </condition>
      </container>
      <container n="BoundaryConditions" pn="Conditions" un="FLBC" icon="nodal" open_window="0" tree_state="open">
        <condition n="AutomaticInlet2D" pn="Automatic inlet velocity" ov="line" ovm="" icon="shells16" help="Automatic inlet velocity" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree">
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='modulus']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='modulus']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_modulus']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_modulus']" att1="state" v1="normal"/>
          </value>
          <value n="function_modulus" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="modulus" pn="Value" v="1.0" units="m/s" unit_magnitude="Velocity" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="direction" pn="Normal direction" v="automatic_inwards_normal" values="automatic_inwards_normal,automatic_outwards_normal" dict="automatic_inwards_normal,Inwards,automatic_outwards_normal,Outwards" state="[ConditionParameterState]" help="Normal direction" show_in_window="1"/>
          <value n="Interval" pn="Time interval" v="Total" values="[getIntervals]" help="Automatic inlet velocity" state="normal"/>
        </condition>
        <condition n="AutomaticInlet3D" pn="Automatic inlet velocity" ov="surface" ovm="" icon="shells16" help="Automatic inlet velocity" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="open">
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='modulus']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='modulus']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_modulus']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_modulus']" att1="state" v1="normal"/>
          </value>
          <value n="function_modulus" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="modulus" pn="Value" v="1.0" units="m/s" unit_magnitude="Velocity" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="direction" pn="Normal direction" v="automatic_inwards_normal" values="automatic_inwards_normal,automatic_outwards_normal" dict="automatic_inwards_normal,Inwards,automatic_outwards_normal,Outwards" state="[ConditionParameterState]" help="Normal direction" show_in_window="1" cal_state="normal"/>
          <value n="Interval" pn="Time interval" v="Total" values="[getIntervals]" help="Automatic inlet velocity" state="normal"/>
          <group n="Automatic inlet velocity Auto1//Total" ov="surface" tree_state="close">
            <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal" v="No" tree_state="close"/>
            <value n="function_modulus" pn="Function" help="Value" state="hidden" show_in_window="1" cal_state="normal" v=""/>
            <value n="modulus" pn="Value" unit_magnitude="Velocity" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal" v="1.0" units="m/s" tree_state="close"/>
            <value n="direction" pn="Normal direction" values="automatic_inwards_normal,automatic_outwards_normal" dict="automatic_inwards_normal,Inwards,automatic_outwards_normal,Outwards" state="[ConditionParameterState]" help="Normal direction" show_in_window="1" cal_state="normal" v="automatic_inwards_normal" tree_state="close"/>
            <value n="Interval" pn="Time interval" values="[getIntervals]" help="Automatic inlet velocity" state="normal" v="Total" tree_state="close"/>
          </group>
        </condition>
        <condition n="Outlet2D" pn="Outlet pressure" ov="point,line" ovm="" icon="shells16" help="Fixes the pressure" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree">
          <value n="constrained" pn="Imposed" v="true" values="true,false" help="Imposed" state="hidden" show_in_window="1"/>
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='value']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='value']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_value']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_value']" att1="state" v1="normal"/>
          </value>
          <value n="function_value" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="value" pn="Value" v="0.0" units="Pa" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="hydrostatic_outlet" pn="Add hydrostatic contribution" v="false" values="true,false" help="If true, adds the hydrostatic pressure component to the outlet pressure." actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies condition="@v='true'" node="../value[@n='h_top']" att1="state" v1="normal"/>
            <dependencies condition="@v!='true'" node="../value[@n='h_top']" att1="state" v1="hidden"/>
          </value>
          <value n="h_top" pn="Top height" v="0.0" units="m" unit_magnitude="L" help="Fluid height above the outlet. If equals 0.0 triangular distribution is considered." string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden"/>
        </condition>
        <condition n="Outlet3D" pn="Outlet pressure" ov="point,line,surface" ovm="" icon="shells16" help="Fixes the pressure to a constant scalar value." state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="open">
          <value n="constrained" pn="Imposed" v="true" values="true,false" help="Imposed" state="hidden" show_in_window="1"/>
          <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" v="No" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies value="No" node="../value[@n='value']" att1="state" v1="normal"/>
            <dependencies value="Yes" node="../value[@n='value']" att1="state" v1="hidden"/>
            <dependencies value="No" node="../value[@n='function_value']" att1="state" v1="hidden"/>
            <dependencies value="Yes" node="../value[@n='function_value']" att1="state" v1="normal"/>
          </value>
          <value n="function_value" pn="Function" v="" help="Value" state="hidden" show_in_window="1" cal_state="normal"/>
          <value n="value" pn="Value" v="0.0" units="Pa" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="hydrostatic_outlet" pn="Add hydrostatic contribution" v="false" values="true,false" help="If true, adds the hydrostatic pressure component to the outlet pressure." actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal">
            <dependencies condition="@v='true'" node="../value[@n='h_top']" att1="state" v1="normal"/>
            <dependencies condition="@v!='true'" node="../value[@n='h_top']" att1="state" v1="hidden"/>
          </value>
          <value n="h_top" pn="Top height" v="0.0" units="m" unit_magnitude="L" help="Fluid height above the outlet. If equals 0.0 triangular distribution is considered." string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden"/>
          <group n="Outlet pressure Auto1" ov="surface" tree_state="close">
            <value n="constrained" pn="Imposed" values="true,false" help="Imposed" state="hidden" show_in_window="1" v="true"/>
            <value n="ByFunction" pn="by function -&gt; f(x,y,z,t)" values="Yes,No" actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal" v="No" tree_state="close"/>
            <value n="function_value" pn="Function" help="Value" state="hidden" show_in_window="1" cal_state="normal" v=""/>
            <value n="value" pn="Value" unit_magnitude="P" help="Value" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal" v="0.0" units="Pa" tree_state="close"/>
            <value n="hydrostatic_outlet" pn="Add hydrostatic contribution" values="true,false" help="If true, adds the hydrostatic pressure component to the outlet pressure." actualize_tree="1" state="[ConditionParameterState]" show_in_window="1" cal_state="normal" v="false" tree_state="close"/>
            <value n="h_top" pn="Top height" unit_magnitude="L" help="Fluid height above the outlet. If equals 0.0 triangular distribution is considered." string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden" v="0.0" units="m"/>
          </group>
        </condition>
        <condition n="Slip2D" pn="Slip" ov="line" ovm="" icon="shells16" help="Slip" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree"/>
        <condition n="Slip3D" pn="Slip" ov="surface" ovm="" icon="shells16" help="Slip" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close"/>
        <condition n="NoSlip2D" pn="No Slip" ov="line" ovm="" icon="shells16" help="No Slip" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree"/>
        <condition n="NoSlip3D" pn="No Slip" ov="surface" ovm="" icon="shells16" help="No Slip" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="open">
          <group n="No Slip Auto1" ov="surface" tree_state="close"/>
        </condition>
        <condition n="WallLaw2D" pn="Wall law" ov="line" ovm="" icon="shells16" help="Wall law" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree">
          <value n="wall_model_name" pn="Wall model" v="navier_slip" values="navier_slip,linear_log" dict="navier_slip,Navier-slip,linear_log,Linear-log" actualize_tree="1" state="[ConditionParameterState]" help="Wall model" show_in_window="1" cal_state="normal">
            <dependencies condition="@v='navier_slip'" node="../value[@n='slip_length']" att1="state" v1="normal"/>
            <dependencies condition="@v!='navier_slip'" node="../value[@n='slip_length']" att1="state" v1="hidden"/>
            <dependencies condition="@v='linear_log'" node="../value[@n='y_wall']" att1="state" v1="normal"/>
            <dependencies condition="@v!='linear_log'" node="../value[@n='y_wall']" att1="state" v1="hidden"/>
          </value>
          <value n="slip_length" pn="Slip length" v="0.001" units="m" unit_magnitude="L" help="Slip length" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="y_wall" pn="Wall distance" v="0.001" units="m" unit_magnitude="L" help="Wall distance" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden"/>
        </condition>
        <condition n="WallLaw3D" pn="Wall law" ov="surface" ovm="" icon="shells16" help="Wall law" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree" tree_state="close">
          <value n="wall_model_name" pn="Wall model" v="navier_slip" values="navier_slip,linear_log" dict="navier_slip,Navier-slip,linear_log,Linear-log" actualize_tree="1" state="[ConditionParameterState]" help="Wall model" show_in_window="1" cal_state="normal">
            <dependencies condition="@v='navier_slip'" node="../value[@n='slip_length']" att1="state" v1="normal"/>
            <dependencies condition="@v!='navier_slip'" node="../value[@n='slip_length']" att1="state" v1="hidden"/>
            <dependencies condition="@v='linear_log'" node="../value[@n='y_wall']" att1="state" v1="normal"/>
            <dependencies condition="@v!='linear_log'" node="../value[@n='y_wall']" att1="state" v1="hidden"/>
          </value>
          <value n="slip_length" pn="Slip length" v="0.001" units="m" unit_magnitude="L" help="Slip length" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="normal"/>
          <value n="y_wall" pn="Wall distance" v="0.001" units="m" unit_magnitude="L" help="Wall distance" string_is="double" state="[ConditionParameterState]" show_in_window="1" cal_state="hidden"/>
        </condition>
        <condition n="VelocityConstraints2D" pn="Custom velocity constraints" ov="line" ovm="" icon="shells16" help="Custom velocity constraints" state="[ConditionState]" update_proc="[OkNewCondition]" check="UpdateTree">
